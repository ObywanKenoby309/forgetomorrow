generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Job {
  id                  Int                      @id @default(autoincrement())
  company             String
  title               String
  worksite            String?
  location            String
  type                String?
  compensation        String?
  description         String
  status              String                   @default("Draft")
  urgent              Boolean                  @default(false)
  viewsCount          BigInt                   @default(0)
  applicationsCount   BigInt                   @default(0)
  createdAt           DateTime                 @default(now())
  updatedAt           DateTime                 @updatedAt
  userId              String
  accountKey          String?
  url                 String?
  salary              String?
  tags                String?
  source              String?
  isTemplate          Boolean                  @default(false)
  templateName        String?
  additionalQuestions Json?
  publishedAt         DateTime?                @db.Timestamptz(6)
  publishedat         DateTime?                @db.Timestamptz(6)
  externalId          String?                  @unique(map: "jobs_external_id_unique")
  search_vector       Unsupported("tsvector")?
  applications        Application[]
  covers              Cover[]
  interviews          Interview[]
  views               JobView[]
  organization        Organization?            @relation("OrganizationJobs", fields: [accountKey], references: [accountKey])
  candidateGroups     CandidateGroup[]
  user                User                     @relation(fields: [userId], references: [id])
  offers              Offer[]
  hireQualityRecords  HireQuality[]
  pinnedBy            PinnedJob[]

  @@index([accountKey])
  @@index([isTemplate])
  @@index([company(ops: raw("gin_trgm_ops"))], map: "jobs_company_trgm_idx", type: Gin)
  @@index([search_vector], type: Gin)
  @@index([tags(ops: raw("gin_trgm_ops"))], map: "jobs_tags_trgm_idx", type: Gin)
  @@index([title(ops: raw("gin_trgm_ops"))], map: "jobs_title_trgm_idx", type: Gin)
  @@map("jobs")
}

model Application {
  id                  Int                       @id @default(autoincrement())
  userId              String
  jobId               Int?
  resumeId            Int?
  coverId             Int?
  appliedAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  status              ApplicationStatus         @default(Applied)
  company             String?
  location            String?
  title               String?
  url                 String?
  notes               String?
  accountKey          String?
  submittedAt         DateTime?
  templateId          String?
  recruiterNotes      String?
  seekerNotes         String?
  answers             ApplicationAnswer[]
  assessment          ApplicationAssessment?
  consent             ApplicationConsent?
  expectations        ApplicationExpectations?
  packetExports       ApplicationPacketExport[]
  selfId              ApplicationSelfId?
  cover               Cover?                    @relation(fields: [coverId], references: [id])
  job                 Job?                      @relation(fields: [jobId], references: [id])
  resume              Resume?                   @relation(fields: [resumeId], references: [id])
  template            ApplicationTemplate?      @relation(fields: [templateId], references: [id])
  user                User                      @relation(fields: [userId], references: [id])
  source              ApplicationSource         @default(FORGETOMORROW)
  externalCandidateId String?
  externalCandidate   ExternalCandidate?        @relation(fields: [externalCandidateId], references: [id])

  @@unique([userId, jobId], name: "user_job_unique")
  @@index([accountKey])
  @@map("applications")
}

model ApplicationExpectations {
  id                String      @id @default(cuid())
  applicationId     Int         @unique
  availability      String?
  startDate         DateTime?
  willingToRelocate String?
  expectedSalary    String?
  workAuthorization String?
  needsSponsorship  Boolean?    @default(false)
  willingToTravel   String?
  notes             String?
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  application       Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_expectations")
}

model ApplicationTemplate {
  id           String                    @id @default(cuid())
  accountKey   String
  name         String                    @default("Default Application")
  version      Int                       @default(1)
  isActive     Boolean                   @default(true)
  createdAt    DateTime                  @default(now())
  updatedAt    DateTime                  @updatedAt
  steps        ApplicationTemplateStep[]
  applications Application[]

  @@index([accountKey])
  @@index([isActive])
  @@map("application_templates")
}

model ApplicationTemplateStep {
  id         String                        @id @default(cuid())
  templateId String
  key        String
  title      String
  order      Int
  questions  ApplicationTemplateQuestion[]
  template   ApplicationTemplate           @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@unique([templateId, key])
  @@index([templateId, order])
  @@map("application_template_steps")
}

model ApplicationTemplateQuestion {
  id       String                  @id @default(cuid())
  stepId   String
  key      String
  label    String
  helpText String?
  type     ApplicationQuestionType
  required Boolean                 @default(false)
  options  Json?
  step     ApplicationTemplateStep @relation(fields: [stepId], references: [id], onDelete: Cascade)

  @@unique([stepId, key])
  @@index([stepId])
  @@map("application_template_questions")
}

model ApplicationAnswer {
  id            String      @id @default(cuid())
  applicationId Int
  questionKey   String
  value         Json
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@unique([applicationId, questionKey])
  @@index([applicationId])
  @@map("application_answers")
}

model ApplicationConsent {
  id                   String      @id @default(cuid())
  applicationId        Int         @unique
  termsAccepted        Boolean     @default(false)
  consentTextVersion   String?
  signatureName        String?
  signedAt             DateTime?
  createdAt            DateTime    @default(now())
  updatedAt            DateTime    @updatedAt
  emailUpdatesAccepted Boolean     @default(false)
  application          Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_consents")
}

model ApplicationSelfId {
  id               String      @id @default(cuid())
  applicationId    Int         @unique
  genderIdentity   String?
  raceEthnicity    String?
  veteranStatus    String?
  disabilityStatus String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  application      Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@map("application_self_id")
}

model ApplicationAssessment {
  id            String      @id @default(cuid())
  applicationId Int         @unique
  result        Json
  score         Int?
  model         String?
  modelVersion  String?
  generatedAt   DateTime?   @default(now())
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  application   Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)

  @@index([applicationId])
  @@map("application_assessments")
}

model ApplicationPacketExport {
  id              String      @id @default(cuid())
  applicationId   Int
  format          String      @default("pdf")
  url             String?
  version         Int?
  createdByUserId String?
  createdAt       DateTime    @default(now())
  application     Application @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  createdBy       User?       @relation("UserApplicationPacketExports", fields: [createdByUserId], references: [id])

  @@index([applicationId])
  @@index([createdByUserId])
  @@map("application_packet_exports")
}

model JobView {
  id       Int      @id @default(autoincrement())
  userId   String
  jobId    Int
  viewedBy String?
  viewedAt DateTime @default(now())
  job      Job      @relation(fields: [jobId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("job_views")
}

model Interview {
  id          Int      @id @default(autoincrement())
  userId      String
  jobId       Int
  scheduledAt DateTime
  status      String   @default("Scheduled")
  job         Job      @relation(fields: [jobId], references: [id])
  user        User     @relation(fields: [userId], references: [id])

  @@map("interviews")
}

model Offer {
  id         Int      @id @default(autoincrement())
  userId     String
  jobId      Int
  salary     String?
  accepted   Boolean?
  receivedAt DateTime @default(now())
  job        Job      @relation(fields: [jobId], references: [id])
  user       User     @relation(fields: [userId], references: [id])

  @@map("offers")
}

model PinnedJob {
  id       Int      @id @default(autoincrement())
  userId   String
  jobId    Int?
  pinnedAt DateTime @default(now())
  company  String?
  location String?
  title    String?
  url      String?
  job      Job?     @relation(fields: [jobId], references: [id])
  user     User     @relation(fields: [userId], references: [id])

  @@map("pinned_jobs")
}

model ExternalJob {
  id          String    @id @default(cuid())
  title       String?
  company     String?   @default("Not Provided")
  location    String?   @default("Not Provided")
  url         String?   @default("Not Provided")
  description String?
  salary      String?
  tags        String?
  publishedAt DateTime? @default(now())
  source      String
  createdAt   DateTime? @default(now())
  updatedAt   DateTime? @updatedAt

  @@index([source])
  @@map("external_jobs")
}

model Resume {
  id           Int           @id @default(autoincrement())
  userId       String
  name         String
  content      String
  isPublic     Boolean       @default(false)
  isPrimary    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("resumes")
}

model Cover {
  id           Int           @id @default(autoincrement())
  userId       String
  jobId        Int?
  name         String
  content      String
  isPublic     Boolean       @default(false)
  isPrimary    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  applications Application[]
  job          Job?          @relation(fields: [jobId], references: [id])
  user         User          @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([jobId])
  @@map("covers")
}

model ScanLog {
  id        String   @id @default(cuid())
  userId    String
  date      String
  score     Int
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@index([userId, createdAt])
  @@map("scan_logs")
}

model UserDraft {
  id        String   @id @default(cuid())
  userId    String
  key       String
  content   Json
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, key], name: "userId_key")
  @@index([userId])
  @@map("user_drafts")
}

model SavedReply {
  id          Int      @id @default(autoincrement())
  userId      String
  persona     String   @default("recruiter")
  text        String
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId, persona])
  @@map("saved_replies")
}

model RecipientGroup {
  id         String   @id @default(cuid())
  userId     String
  accountKey String?
  persona    String   @default("recruiter")
  name       String
  memberIds  String[]
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([userId, persona])
  @@index([accountKey, persona])
  @@map("recipient_groups")
}

model AiThread {
  id        String      @id @default(cuid())
  userId    String
  mode      AiBuddyMode
  title     String?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AiMessage[]
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, mode], name: "userId_mode_unique")
  @@index([userId])
  @@index([mode])
  @@map("ai_threads")
}

model AiMessage {
  id        String   @id @default(cuid())
  threadId  String
  role      String
  content   String
  metadata  Json?
  createdAt DateTime @default(now())
  thread    AiThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId, createdAt])
  @@index([role])
  @@map("ai_messages")
}

model VerificationToken {
  id           Int      @id @default(autoincrement())
  token        String   @unique
  email        String
  firstName    String
  lastName     String
  passwordHash String
  plan         String?
  newsletter   Boolean  @default(false)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@map("verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  tokenHash String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@index([createdAt])
  @@map("password_reset_tokens")
}

model CareerRoadmap {
  id          String   @id @default(cuid())
  userId      String
  generatedAt DateTime @default(now())
  data        Json
  pdfUrl      String?
  isPro       Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  user        User     @relation("UserCareerRoadmaps", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Negotiation {
  id        String   @id @default(cuid())
  userId    String
  input     Json
  result    Json
  pdfUrl    String?
  createdAt DateTime @default(now())
  user      User     @relation("UserNegotiations", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model ProfileSnapshot {
  id        String   @id @default(cuid())
  userId    String
  headline  String?
  bio       String?
  skills    String
  resumeId  String?
  createdAt DateTime @default(now())
  user      User     @relation("UserProfileSnapshots", fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model UserConsent {
  id          Int      @id @default(autoincrement())
  userId      String
  consentType String
  region      String?
  given       Boolean  @default(true)
  timestamp   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, consentType])
  @@map("user_consents")
}

model AppointmentRequest {
  id           String   @id @default(cuid())
  coachId      String
  requesterId  String
  spotlightId  String
  preferredSlots Json   // array of ISO datetime strings, max 3
  timezone     String
  message      String?
  status            String   @default("PENDING") // PENDING | CONFIRMED | DECLINED | RESCHEDULED
  suggestedAt       DateTime?
  coachNotes        String?
  contactRequestId  String?  // links to the ContactRequest created alongside this booking
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
  coach             User     @relation("AppointmentRequestsAsCoach",     fields: [coachId],     references: [id], onDelete: Cascade)
  requester         User     @relation("AppointmentRequestsAsRequester", fields: [requesterId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([requesterId])
  @@index([status])
  @@map("appointment_requests")
}

model CoachingClient {
  id                String             @id @default(cuid())
  coachId           String
  clientId          String?
  status            String             @default("Active")
  nextSession       DateTime?
  lastContact       DateTime?
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  email             String?
  name              String
  notes             String?
  client            User?              @relation("CoachClientsClient", fields: [clientId], references: [id], onDelete: Cascade)
  coach             User               @relation("CoachClientsCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachingDocuments CoachingDocument[] @relation("ClientDocuments")
  coachingNotes     CoachingNote[]     @relation("ClientNotes")
  sessions          CoachingSession[]  @relation("ClientSessions")
  manualSummary            String?
  manualExperience         String?
  manualEducation          String?
  manualSkills             String?
  manualWorkStatus         String?
  manualPreferredWorkType  String?
  manualPreferredLocations String?
  manualWillingToRelocate  String?
  targetCompanies         String?
  strategyBackground      String?
  strategyThemes          String?
  strategyRoleLanes       String?
  strategyNextStep        String?
  strategyJson            Json?

  @@index([coachId])
  @@index([clientId])
  @@map("coaching_clients")
}

model CoachingSession {
  id               String          @id @default(cuid())
  coachId          String
  clientId         String?
  coachingClientId String?
  startAt          DateTime
  durationMin      Int             @default(60)
  type             String          @default("Strategy")
  status           String          @default("Scheduled")
  followUpDueAt    DateTime?
  followUpDone     Boolean         @default(false)
  notes            String?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  client           User?           @relation("CoachSessionsClient", fields: [clientId], references: [id], onDelete: Cascade)
  coach            User            @relation("CoachSessionsCoach", fields: [coachId], references: [id], onDelete: Cascade)
  coachingClient   CoachingClient? @relation("ClientSessions", fields: [coachingClientId], references: [id])

  @@index([coachId])
  @@index([clientId])
  @@index([startAt])
  @@index([coachingClientId])
  @@map("coaching_sessions")
}

model CoachingNote {
  id               String         @id @default(cuid())
  coachingClientId String
  coachId          String
  body             String
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  coach            User           @relation("CoachNotes", fields: [coachId], references: [id], onDelete: Cascade)
  coachingClient   CoachingClient @relation("ClientNotes", fields: [coachingClientId], references: [id], onDelete: Cascade)

  @@index([coachingClientId])
  @@index([coachId])
  @@map("coaching_notes")
}

model CoachingDocument {
  id               String         @id @default(cuid())
  coachingClientId String
  coachId          String
  title            String
  url              String
  type             String         @default("Other")
  uploadedAt       DateTime       @default(now())
  createdAt        DateTime       @default(now())
  coach            User           @relation("CoachDocuments", fields: [coachId], references: [id], onDelete: Cascade)
  coachingClient   CoachingClient @relation("ClientDocuments", fields: [coachingClientId], references: [id], onDelete: Cascade)

  @@index([coachingClientId])
  @@index([coachId])
  @@map("coaching_documents")
}

model CoachingCsatResponse {
  id           String   @id @default(cuid())
  coachId      String
  satisfaction Int
  timeliness   Int
  quality      Int
  comment      String?
  anonymous    Boolean  @default(true)
  createdAt    DateTime @default(now())
  coach        User     @relation("UserCoachingCsatResponses", fields: [coachId], references: [id], onDelete: Cascade)

  @@index([coachId])
  @@index([createdAt])
  @@map("coaching_csat_responses")
}

model HearthSpotlight {
  id           String   @id @default(cuid())
  userId       String   @unique
  name         String
  headline     String
  summary      String
  specialties  Json
  rate         String   @default("Free")
  availability String   @default("Open to discuss")
  contactEmail String?
  hook         String?
  whyICoach    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([createdAt])
  @@map("hearth_spotlights")
}

model Contact {
  id            String   @id @default(cuid())
  userId        String
  contactUserId String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  contactUser   User     @relation("UserContactsAsContact", fields: [contactUserId], references: [id], onDelete: Cascade)
  user          User     @relation("UserContacts", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, contactUserId])
  @@unique([userId, contactUserId], map: "contacts_userid_contactuserid_key")
  @@index([userId])
  @@index([contactUserId])
  @@map("contacts")
}

model ContactRequest {
  id         String               @id @default(cuid())
  fromUserId String
  toUserId   String
  status     ContactRequestStatus @default(PENDING)
  type       String               @default("GENERAL") // GENERAL | COACHING_REQUEST
  createdAt  DateTime             @default(now())
  updatedAt  DateTime             @updatedAt
  fromUser   User                 @relation("UserContactRequestsFrom", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser     User                 @relation("UserContactRequestsTo", fields: [toUserId], references: [id], onDelete: Cascade)

  @@unique([fromUserId, toUserId])
  @@unique([fromUserId, toUserId], map: "contact_requests_fromuserid_touserid_key")
  @@index([fromUserId])
  @@index([toUserId])
  @@map("contact_requests")
}

model Organization {
  id                 String               @id @default(cuid())
  name               String
  status             OrganizationStatus   @default(PILOT)
  accountKey         String               @unique
  ownerUserId                   String?
  stalledCandidateThresholdDays Int?
  createdAt                     DateTime             @default(now())
  updatedAt                     DateTime             @updatedAt
  externalCandidates ExternalCandidate[]  @relation("OrganizationExternalCandidates")
  jobs               Job[]                @relation("OrganizationJobs")
  members            OrganizationMember[] @relation("OrganizationMembers")
  owner              User?                @relation("OrganizationOwner", fields: [ownerUserId], references: [id])
  slaOverrides       SlaPolicy[]
  talentPools        TalentPool[]         @relation("OrganizationTalentPools")
  tickets            Ticket[]             @relation("OrgTickets")
  users              User[]               @relation("OrganizationUsers")

  @@index([ownerUserId])
  @@map("organizations")
}

model OrganizationMember {
  id           String       @id @default(cuid())
  accountKey   String
  userId       String
  role         String?
  createdAt    DateTime     @default(now())
  organization Organization @relation("OrganizationMembers", fields: [accountKey], references: [accountKey], onDelete: Cascade)
  user         User         @relation("UserOrganizationMembers", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([accountKey, userId])
  @@index([accountKey])
  @@index([userId])
  @@map("organization_members")
}

model UserStaffRole {
  id        String    @id @default(cuid())
  userId    String
  role      StaffRole
  createdAt DateTime  @default(now())
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([role])
  @@index([userId])
  @@map("user_staff_roles")
}

model AuditLog {
  id                 String   @id @default(cuid())
  actorUserId        String
  impersonatedUserId String?
  action             String
  metadata           Json?
  createdAt          DateTime @default(now())
  actor              User     @relation("AuditActor", fields: [actorUserId], references: [id], onDelete: Cascade)
  impersonatedUser   User?    @relation("AuditImpersonated", fields: [impersonatedUserId], references: [id])

  @@index([actorUserId])
  @@index([impersonatedUserId])
  @@index([createdAt])
  @@map("audit_logs")
}

model User {
  id                           String                         @id @default(cuid())
  email                        String                         @unique
  aboutMe                      String?
  accountKey                   String?
  avatarUrl                    String?
  bannerFocalY                 Int?
  bannerHeight                 Int?
  bannerMode                   String?
  corporateBannerKey           String?
  corporateBannerLocked        Boolean                        @default(false)
  coverUrl                     String?
  createdAt                    DateTime                       @default(now())
  deletedAt                    DateTime?
  emailVerificationExpiresAt   DateTime?
  emailVerificationToken       String?                        @unique
  emailVerified                Boolean                        @default(false)
  firstName                    String?
  headline                     String?
  hobbiesJson                  Json?
  image                        String?
  isProfilePublic              Boolean                        @default(false)
  languagesJson                Json?
  lastName                     String?
  location                     String?
  mfaEnabled                   Boolean                        @default(false)
  mfaSecret                    String?
  name                         String?
  newsletter                   Boolean                        @default(false)
  passwordHash                 String?
  plan                         Tier                           @default(FREE)
  pronouns                     String?
  skillsJson                   Json?
  socialLinks                  Json?
  certificationsJson           Json?
  customSectionJson            Json?
  projectsJson                 Json?
  slug                         String?                        @unique
  slugChangeCount              Int                            @default(0)
  slugLastChangedAt            DateTime?
  status                       String?
  stripeCustomerId             String?                        @unique
  stripeSubscriptionId         String?                        @unique
  updatedAt                    DateTime                       @updatedAt
  wallpaperUrl                 String?
  workPreferences              Json?
  role                         UserRole                       @default(SEEKER)
  profileVisibility            ProfileVisibility              @default(PRIVATE)
  educationJson                Json?
  resumeAlignFreeUses          Int                            @default(0)
