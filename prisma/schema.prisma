  businessStart    Int           @default(9)
  businessEnd      Int           @default(17)
  businessDays     Json          @default("[1, 2, 3, 4, 5]")
  timezone         String        @default("America/New_York")
  warningThreshold Int           @default(75)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  organization     Organization? @relation(fields: [orgId], references: [id])
  queue            Queue?        @relation(fields: [queueId], references: [id])
  tickets          Ticket[]

  @@index([orgId])
  @@map("sla_policies")
}

model Ticket {
  id              String             @id @default(cuid())
  number          Int                @unique @default(autoincrement())
  type            TicketType
  priority        TicketPriority     @default(P3)
  status          TicketStatus       @default(OPEN)
  title           String
  description     String?
  queueId         String
  assignedToId    String?
  createdById     String
  requesterId     String?
  requesterOrgId  String?
  slaPolicyId     String?
  slaResponseDue  DateTime?
  slaResolveDue   DateTime?
  slaResponseMet  Boolean?
  slaResolveMet   Boolean?
  slaBreached     Boolean            @default(false)
  firstResponseAt DateTime?
  resolvedAt      DateTime?
  closedAt        DateTime?
  parentId        String?
  tags            Json?
  source          TicketSource       @default(AGENT)
  externalRef     String?
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  slaEvents       SlaEvent[]
  attachments     TicketAttachment[]
  comments        TicketComment[]
  history         TicketHistory[]
  assignedTo      User?              @relation("TicketAssignedTo", fields: [assignedToId], references: [id])
  createdBy       User               @relation("TicketCreatedBy", fields: [createdById], references: [id])
  parent          Ticket?            @relation("TicketChildren", fields: [parentId], references: [id])
  children        Ticket[]           @relation("TicketChildren")
  queue           Queue              @relation(fields: [queueId], references: [id])
  requester       User?              @relation("TicketRequester", fields: [requesterId], references: [id])
  requesterOrg    Organization?      @relation("OrgTickets", fields: [requesterOrgId], references: [id])
  slaPolicy       SlaPolicy?         @relation(fields: [slaPolicyId], references: [id])
  workflowRuns    WorkflowRun[]

  @@index([queueId])
  @@index([assignedToId])
  @@index([requesterId])
  @@index([requesterOrgId])
  @@index([status])
  @@index([priority])
  @@index([type])
  @@index([slaBreached])
  @@index([parentId])
  @@index([createdAt])
  @@map("tickets")
}

model TicketComment {
  id         String   @id @default(cuid())
  ticketId   String
  authorId   String
  body       String
  isInternal Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  author     User     @relation("TicketCommentAuthor", fields: [authorId], references: [id])
  ticket     Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([authorId])
  @@map("ticket_comments")
}

model TicketHistory {
  id        String   @id @default(cuid())
  ticketId  String
  actorId   String
  action    String
  fromValue String?
  toValue   String?
  metadata  Json?
  createdAt DateTime @default(now())
  actor     User     @relation("TicketHistoryActor", fields: [actorId], references: [id])
  ticket    Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([actorId])
  @@map("ticket_history")
}

model TicketAttachment {
  id           String   @id @default(cuid())
  ticketId     String
  uploadedById String
  filename     String
  url          String
  mimeType     String?
  sizeBytes    Int?
  createdAt    DateTime @default(now())
  ticket       Ticket   @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  uploadedBy   User     @relation("TicketAttachmentUploader", fields: [uploadedById], references: [id])

  @@index([ticketId])
  @@map("ticket_attachments")
}

model SlaEvent {
  id       String       @id @default(cuid())
  ticketId String
  type     SlaEventType
  target   String
  firedAt  DateTime     @default(now())
  notified Boolean      @default(false)
  ticket   Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([type])
  @@map("sla_events")
}

model WorkflowRule {
  id          String          @id @default(cuid())
  name        String
  description String?
  isActive    Boolean         @default(true)
  trigger     WorkflowTrigger
  conditions  Json
  actions     Json
  runOrder    Int             @default(0)
  createdById String
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  createdBy   User            @relation("WorkflowRuleCreator", fields: [createdById], references: [id])
  runs        WorkflowRun[]

  @@index([isActive, trigger])
  @@index([createdById])
  @@map("workflow_rules")
}

model WorkflowRun {
  id        String       @id @default(cuid())
  ruleId    String
  ticketId  String
  status    String       @default("success")
  log       Json?
  createdAt DateTime     @default(now())
  rule      WorkflowRule @relation(fields: [ruleId], references: [id])
  ticket    Ticket       @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ruleId])
  @@index([ticketId])
  @@index([createdAt])
  @@map("workflow_runs")
}

